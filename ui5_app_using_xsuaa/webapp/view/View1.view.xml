<mvc:View controllerName="ui5appusingxsuaa.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">
        <content>
            <VBox id="_IDGenVBox" class="sapUiMediumMargin" width="100%">

                <!-- ═══════════════════════════════════════ -->
                <!--           SECURITY SCOPES SECTION      -->
                <!-- ═══════════════════════════════════════ -->
                <Panel id="_IDGenPanel1" headerText="Security Scopes" expandable="true" expanded="true"
                    class="sapUiSmallMarginBottom">
                    <content>
                        <VBox id="_IDGenVBox1" class="sapUiSmallMargin">
                            <Text id="_IDGenText"
                                text="Check which scopes are assigned to the current user."
                                class="sapUiTinyMarginBottom"
                            />
                            <Button id="_IDGenButton"
                                text="Check My Scopes"
                                type="Emphasized"
                                press="onCheckSecurity"
                                icon="sap-icon://locked"
                            />
                            <Text id="securityResult" text="" class="sapUiTinyMarginTop" />
                        </VBox>
                    </content>
                </Panel>

            </VBox>
        </content>
    </Page>
</mvc:View>