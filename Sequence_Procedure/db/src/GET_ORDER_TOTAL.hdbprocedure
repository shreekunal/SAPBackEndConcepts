PROCEDURE GET_ORDER_TOTAL(
    IN  IV_ORDER_ID  NVARCHAR(36),
    OUT ET_RESULT    TABLE (
        TOTAL DECIMAL(15, 2)
    )
)
LANGUAGE SQLSCRIPT
SQL SECURITY INVOKER
AS
BEGIN
    ET_RESULT = SELECT COALESCE(SUM(QUANTITY * PRICE), 0.00) AS TOTAL
                FROM SALES_SALESORDERITEMS
                WHERE PARENT_ID = IV_ORDER_ID;
END
