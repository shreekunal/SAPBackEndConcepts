<mvc:View controllerName="multipledestinoneui5.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page id="page" title="Books &amp; Authors">
        <content>
            <Table id="booksTable"
                items="{path: '/Books'}">
                <headerToolbar>
                    <OverflowToolbar>
                        <Title text="Books List" />
                    </OverflowToolbar>
                </headerToolbar>
                <columns>
                    <Column>
                        <Text text="ID" />
                    </Column>
                    <Column>
                        <Text text="Title" />
                    </Column>
                    <Column>
                        <Text text="Author" />
                    </Column>
                </columns>
                <items>
                    <ColumnListItem>
                        <cells>
                            <Text text="{ID}" />
                            <Text text="{title}" />
                            <Text text="{author}" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>

            <Table id="authorsTable"
                items="{model: 'AUTHORS', path: '/Authors'}">
                <headerToolbar>
                    <OverflowToolbar>
                        <Title text="Authors List" />
                    </OverflowToolbar>
                </headerToolbar>
                <columns>
                    <Column>
                        <Text text="Name" />
                    </Column>
                    <Column>
                        <Text text="Birth Year" />
                    </Column>
                    <Column>
                        <Text text="Country" />
                    </Column>
                </columns>
                <items>
                    <ColumnListItem>
                        <cells>
                            <Text text="{AUTHORS>name}" />
                            <Text text="{AUTHORS>birthYear}" />
                            <Text text="{AUTHORS>country}" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
</mvc:View>