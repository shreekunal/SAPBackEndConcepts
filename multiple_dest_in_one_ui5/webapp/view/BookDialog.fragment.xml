<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Dialog title="{bookDialog>/title}">
        <content>
            <VBox class="sapUiSmallMargin">
                <Input placeholder="ID (integer)"  value="{bookDialog>/ID}" />
                <Input placeholder="Title"         value="{bookDialog>/bookTitle}" />
                <Input placeholder="Author"        value="{bookDialog>/author}" />
            </VBox>
        </content>
        <beginButton>
            <Button text="Save" type="Emphasized" press="onSaveBook" />
        </beginButton>
        <endButton>
            <Button text="Cancel" press="onCancelBook" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
